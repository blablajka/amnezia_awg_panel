# ============================================================
# Amnezia VPN System — Environment Configuration
# Скопируйте этот файл как .env и заполните значения
# ============================================================

# ── Telegram Bot ──────────────────────────────────────────────
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Telegram ID администраторов (через запятую)
ADMIN_IDS=[123456789,987654321]

# ── YooKassa ──────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=test_secret_key
YOOKASSA_RETURN_URL=https://t.me/your_bot

# ── Database ──────────────────────────────────────────────────
# SQLite (по умолчанию):
DATABASE_URL=sqlite+aiosqlite:///./vpn_system.db
# PostgreSQL (для продакшна):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vpn_system

# ── Web Admin Panel ──────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── Webhook ──────────────────────────────────────────────────
# Публичный URL вашего сервера (для YooKassa webhook)
WEBHOOK_BASE_URL=https://yourdomain.com
WEBHOOK_PATH=/api/yookassa/webhook

# ── Цены подписок (рубли) ────────────────────────────────────
PRICE_1_MONTH=290
PRICE_3_MONTHS=690
PRICE_12_MONTHS=2490
